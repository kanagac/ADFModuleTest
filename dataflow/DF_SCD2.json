{
	"name": "DF_SCD2",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_SQL_PHRMCY",
						"type": "DatasetReference"
					},
					"name": "SrcPharmcy"
				},
				{
					"dataset": {
						"referenceName": "DS_SQL_TGT",
						"type": "DatasetReference"
					},
					"name": "TgtDIMPTNT"
				},
				{
					"dataset": {
						"referenceName": "DS_SQL_STATUS",
						"type": "DatasetReference"
					},
					"name": "SrcStatus"
				},
				{
					"dataset": {
						"referenceName": "DS_SQL_LU_LANGUAGE",
						"type": "DatasetReference"
					},
					"name": "SrcLanguage"
				}
			],
			"sinks": [],
			"transformations": [
				{
					"name": "LeftJoinStatus"
				},
				{
					"name": "LeftJoinLanguage"
				},
				{
					"name": "LeftSrcTgt"
				},
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          PHRMCY_NAT_PROV_ID_NBR as string,",
				"          PHRMCY_NCPDP_NBR as double,",
				"          PTNT_CD as string,",
				"          PSCB_FIRST_NM as string,",
				"          PSCB_LAST_NM as string,",
				"          LANG_CD as string,",
				"          DEAL_ID as string,",
				"          PHRMCY_NM as string,",
				"          PHRMCY_ST_ADDR_LINE1_TXT as string,",
				"          PHRMCY_ADDR_ZIP_CD as double,",
				"          PHRMCY_ADDR_CITY_NM as string,",
				"          PHRMCY_ADDR_ST_CD as string,",
				"          PHRMCY_ADDR_ST_NAME as string,",
				"          PHRMCY_ADDR_ZNE_CD as string,",
				"          PHRMCY_ADDR_ZNE_NM as string,",
				"          PHRMCY_SYS_IVR_DTA_STRT_DT as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> SrcPharmcy",
				"source(output(",
				"          PTNT_KEY as integer,",
				"          PTNT_ID as integer,",
				"          PTNT_CD as string,",
				"          PHRMCY_NCPDP_NBR as integer,",
				"          PHRMCY_NAT_PROV_ID_NBR as string,",
				"          PSCB_FIRST_NM as string,",
				"          PHRMCY_NM as string,",
				"          PHRMCY_ADDR_CITY_NM as string,",
				"          PHRMCY_ADDR_ST_NM as string,",
				"          PHRMCY_ADDR_ZNE_NM as string,",
				"          PHRMCY_ADDR_ZIP_CD as string,",
				"          PSCB_EMAIL_ID as string,",
				"          PHRMCY_SYS_IVR_DTA_STRT_DT as string,",
				"          PHRMCY_SYS_IVR_DTA_STRT_QTR as string,",
				"          PHRMCY_SYS_IVR_DTA_STRT_YR as string,",
				"          PHRMCY_AGE as integer,",
				"          DEAL_ID as string,",
				"          DEAL_TYPE_CD as string,",
				"          DEAL_NUMBER as string,",
				"          LANG_CD as string,",
				"          LANG_DESC as string,",
				"          RCD_CRT_TMS as timestamp,",
				"          START_DATE as timestamp,",
				"          END_DATE as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> TgtDIMPTNT",
				"source(output(",
				"          deal_id as string,",
				"          deal_nbr as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> SrcStatus",
				"source(output(",
				"          LANG_ID as integer,",
				"          LANG_CD as string,",
				"          LANG_DESC as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> SrcLanguage",
				"SrcPharmcy, SrcStatus join(SrcPharmcy@DEAL_ID == SrcStatus@deal_id,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> LeftJoinStatus",
				"SrcPharmcy, SrcLanguage join(SrcPharmcy@LANG_CD == SrcLanguage@LANG_CD,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> LeftJoinLanguage",
				"SrcPharmcy, TgtDIMPTNT join(ERROR_FUNCTION('') == ERROR_FUNCTION(''),",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> LeftSrcTgt",
				"LeftSrcTgt derive(PTNT_KEY = PTNT_KEY,",
				"          PTNT_ID = replace(' ',''),",
				"          PTNT_CD = right(SrcPharmcy@PTNT_CD, 4),",
				"          PHRMCY_NCPDP_NBR = SrcPharmcy@PHRMCY_NCPDP_NBR,",
				"          PHRMCY_NAT_PROV_ID_NBR = case(SrcPharmcy@PHRMCY_NAT_PROV_ID_NBR == 'null', 'UNK', SrcPharmcy@PHRMCY_NAT_PROV_ID_NBR),",
				"          PSCB_FIRST_NM = SrcPharmcy@PSCB_FIRST_NM,",
				"          PSCB_LAST_NM = PSCB_LAST_NM,",
				"          PHRMCY_NM = replace('-&,',' '),",
				"          PHRMCY_ADDR_CITY_NM = initCap(SrcPharmcy@PHRMCY_ADDR_CITY_NM),",
				"          PHRMCY_ADDR_ST_NM = initCap(PHRMCY_ADDR_ST_NM),",
				"          PHRMCY_ADDR_ZNE_NM = initCap(SrcPharmcy@PHRMCY_ADDR_ZNE_NM),",
				"          PHRMCY_ADDR_ZNE_CD = lpad('SrcPharmcy@PHRMCY_ADDR_ZIP_CD', 5, '0'),",
				"          PSCB_EMAIL_ID = PSCB_EMAIL_ID,",
				"          PHRMCY_SYS_IVR_DTA_STRT_DT = ERROR_FUNCTION(''),",
				"          PHRMCY_SYS_IVR_DTA_STRT_QTR = ERROR_FUNCTION(''),",
				"          PHRMCY_SYS_IVR_DTA_STRT_YR = ERROR_FUNCTION(''),",
				"          {} = ERROR_FUNCTION(''),",
				"          DEAL_NUMBER = ERROR_FUNCTION(''),",
				"          column6 = ERROR_FUNCTION(''),",
				"          column7 = ERROR_FUNCTION('')) ~> derivedColumn1"
			]
		}
	}
}
{
	"name": "DF_DIM_PTNT",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_SOURCE",
						"type": "DatasetReference"
					},
					"name": "PHRMCY"
				},
				{
					"dataset": {
						"referenceName": "DS_SOURCE",
						"type": "DatasetReference"
					},
					"name": "STATUS"
				},
				{
					"dataset": {
						"referenceName": "DS_SOURCE",
						"type": "DatasetReference"
					},
					"name": "LANG"
				},
				{
					"dataset": {
						"referenceName": "DS_TARGET",
						"type": "DatasetReference"
					},
					"name": "TARGETSCD"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DS_TARGET",
						"type": "DatasetReference"
					},
					"name": "sink1"
				},
				{
					"dataset": {
						"referenceName": "DS_TARGET",
						"type": "DatasetReference"
					},
					"name": "sink2"
				},
				{
					"dataset": {
						"referenceName": "DS_TARGET",
						"type": "DatasetReference"
					},
					"name": "sink3"
				},
				{
					"dataset": {
						"referenceName": "DS_TARGET",
						"type": "DatasetReference"
					},
					"name": "sink4"
				}
			],
			"transformations": [
				{
					"name": "exceptUsPr"
				},
				{
					"name": "PhrStatus"
				},
				{
					"name": "JoinLan"
				},
				{
					"name": "ToMapSrc"
				},
				{
					"name": "JoinTarget"
				},
				{
					"name": "Transformations"
				},
				{
					"name": "split1"
				},
				{
					"name": "derivedColumn1"
				},
				{
					"name": "derivedColumn2"
				},
				{
					"name": "derivedColumn3"
				},
				{
					"name": "alterRow1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          PHRMCY_NAT_PROV_ID_NBR as string,",
				"          PHRMCY_NCPDP_NBR as double,",
				"          PTNT_CD as string,",
				"          PSCB_FIRST_NM as string,",
				"          PSCB_LAST_NM as string,",
				"          LANG_CD as string,",
				"          DEAL_ID as string,",
				"          PHRMCY_NM as string,",
				"          PHRMCY_ST_ADDR_LINE1_TXT as string,",
				"          PHRMCY_ADDR_ZIP_CD as double,",
				"          PHRMCY_ADDR_CITY_NM as string,",
				"          PHRMCY_ADDR_ST_CD as string,",
				"          PHRMCY_ADDR_ST_NAME as string,",
				"          PHRMCY_ADDR_ZNE_CD as string,",
				"          PHRMCY_ADDR_ZNE_NM as string,",
				"          PHRMCY_SYS_IVR_DTA_STRT_DT as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> PHRMCY",
				"source(output(",
				"          deal_id as string,",
				"          deal_nbr as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> STATUS",
				"source(output(",
				"          LANG_ID as integer,",
				"          LANG_CD as string,",
				"          LANG_DESC as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> LANG",
				"source(output(",
				"          PTNT_KEY as integer,",
				"          PTNT_ID as integer,",
				"          PTNT_CD as string,",
				"          PHRMCY_NCPDPNBR as integer,",
				"          PHRMCY_NAT_PROV_ID_NBR as string,",
				"          PSCB_FIRST_NM as string,",
				"          PSCB_LAST_NM as string,",
				"          PHRMCY_NM as string,",
				"          PHRMCY_ADDR_CITY_NM as string,",
				"          PHRMCY_ADDR_ST_NM as string,",
				"          PHRMCY_ADDR_ZNE_NM as string,",
				"          PHRMCY_ADDR_ZIP_CD as string,",
				"          PSCB_EMAIL_ID as string,",
				"          PHRMCY_SYS_IVR_DTA_STRT_DT as string,",
				"          PHRMCY_SYS_IVR_DTA_STRT_QTY as string,",
				"          PHRMCY_SYS_IVR_DTA_STRT_YR as string,",
				"          PHRMCY_AGE as integer,",
				"          DEAL_ID as string,",
				"          DEAL_TYPE_CD as string,",
				"          LANG_CD as string,",
				"          LANG_DESC as string,",
				"          RCD_CRT_TMS as timestamp,",
				"          RCD_MOD_TMS as timestamp,",
				"          START_DATE as timestamp,",
				"          END_DATE as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> TARGETSCD",
				"PHRMCY filter(PHRMCY_ADDR_ZNE_CD != 'US' && PHRMCY_ADDR_ZNE_CD != 'PR') ~> exceptUsPr",
				"exceptUsPr, STATUS join(PHRMCY@DEAL_ID == STATUS@deal_id",
				"     && PHRMCY@DEAL_ID == deal_nbr,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> PhrStatus",
				"PhrStatus, LANG join(PHRMCY@LANG_CD == LANG@LANG_CD,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> JoinLan",
				"JoinLan select(mapColumn(",
				"          {src.PHRMCY_NAT_PROV_ID_NBR} = PHRMCY_NAT_PROV_ID_NBR,",
				"          {src.PHRMCY_NCPDP_NBR} = PHRMCY_NCPDP_NBR,",
				"          {src.PTNT_CD} = PTNT_CD,",
				"          {src.PSCB_FIRST_NM} = PSCB_FIRST_NM,",
				"          {src.PSCB_LAST_NM} = PSCB_LAST_NM,",
				"          {src.LANG_CD} = PHRMCY@LANG_CD,",
				"          {src.DEAL_ID} = PHRMCY@DEAL_ID,",
				"          {src.PHRMCY_NM} = PHRMCY_NM,",
				"          {src.PHRMCY_ST_ADDR_LINE1_TXT} = PHRMCY_ST_ADDR_LINE1_TXT,",
				"          {src.PHRMCY_ADDR_ZIP_CD} = PHRMCY_ADDR_ZIP_CD,",
				"          {src.PHRMCY_ADDR_CITY_NM} = PHRMCY_ADDR_CITY_NM,",
				"          {src.PHRMCY_ADDR_ST_CD} = PHRMCY_ADDR_ST_CD,",
				"          {src.PHRMCY_ADDR_ST_NAME} = PHRMCY_ADDR_ST_NAME,",
				"          {src.PHRMCY_ADDR_ZNE_CD} = PHRMCY_ADDR_ZNE_CD,",
				"          {src.PHRMCY_ADDR_ZNE_NM} = PHRMCY_ADDR_ZNE_NM,",
				"          {src.PHRMCY_SYS_IVR_DTA_STRT_DT} = PHRMCY_SYS_IVR_DTA_STRT_DT,",
				"          {src.deal_id} = STATUS@deal_id,",
				"          {src.deal_nbr} = deal_nbr,",
				"          {src.LANG_ID} = LANG_ID,",
				"          {src.LANG_CD} = LANG@LANG_CD,",
				"          {src.LANG_DESC} = LANG_DESC",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> ToMapSrc",
				"ToMapSrc, TARGETSCD join(ERROR_FUNCTION('') == ERROR_FUNCTION(''),",
				"     joinType:'inner',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> JoinTarget",
				"JoinTarget derive(PTNT_KEY = add(PTNT_KEY, 1),",
				"          PTNT_ID = regexReplace({src.PTNT_CD},'[\\b+]',''),",
				"          PTNT_CD = right({src.PTNT_CD}, 4),",
				"          PHRMCY_NCPDPNBR = {src.PHRMCY_NCPDP_NBR},",
				"          PHRMCY_NAT_PROV_ID_NBR = iifNull('UNK', {src.PHRMCY_NAT_PROV_ID_NBR}),",
				"          PSCB_FIRST_NM = {src.PSCB_FIRST_NM},",
				"          PSCB_LAST_NM = {src.PSCB_LAST_NM},",
				"          PHRMCY_NM = regexReplace({src.PHRMCY_NM},\"[-&']\",' '),",
				"          PHRMCY_ADDR_CITY_NM = iif(regexMatch({src.PHRMCY_ADDR_CITY_NM}, ' '),left({src.PHRMCY_ADDR_CITY_NM},1),left({src.PHRMCY_ADDR_CITY_NM},3)),",
				"          PHRMCY_ADDR_ST_NM = initCap({src.PHRMCY_ADDR_ST_NAME}),",
				"          PHRMCY_ADDR_ZNE_NM = initCap({src.PHRMCY_ADDR_ZNE_NM}),",
				"          PHRMCY_ADDR_ZIP_CD = iif(length(toString({src.PHRMCY_ADDR_ZIP_CD})) == 5,{src.PHRMCY_ADDR_ZIP_CD},toDouble(lpad(toString({src.PHRMCY_ADDR_ZIP_CD}),5,'0'))),",
				"          PSCB_EMAIL_ID = concat(left({src.PSCB_FIRST_NM},length({src.PSCB_FIRST_NM})/2),left({src.PSCB_LAST_NM},1),\"@UN.com\"),",
				"          PHRMCY_SYS_IVR_DTA_STRT_DT = concat(toString(dayOfMonth({src.PHRMCY_SYS_IVR_DTA_STRT_DT})),'-',toString(month({src.PHRMCY_SYS_IVR_DTA_STRT_DT})),'-',toString(year({src.PHRMCY_SYS_IVR_DTA_STRT_DT}))),",
				"          PHRMCY_SYS_IVR_DTA_STRT_QTY = concat('O','-',toString(year({src.PHRMCY_SYS_IVR_DTA_STRT_DT}))),",
				"          PHRMCY_SYS_IVR_DTA_STRT_YR = toString({src.PHRMCY_SYS_IVR_DTA_STRT_DT}),",
				"          PHRMCY_AGE = minus(year(currentTimestamp()),year({src.PHRMCY_SYS_IVR_DTA_STRT_DT})),",
				"          DEAL_ID = 'exist',",
				"          DEAL_TYPE_CD = left({src.deal_nbr},2),",
				"          DEAL_NUMBER = right({src.deal_nbr}, length({src.deal_nbr})-2),",
				"          LANG_CD = {src.LANG_CD},",
				"          LANG_DESC = {src.LANG_DESC},",
				"          RCD_CRT_TMS = currentTimestamp(),",
				"          RCD_MOD_TMS = ERROR_FUNCTION(''),",
				"          START_DATE = currentTimestamp(),",
				"          END_DATE = ERROR_FUNCTION('')) ~> Transformations",
				"Transformations split(isNull({PHRMCY_ADDR_ZIP_CD}),",
				"     !isNull(PHRMCY_ADDR_ZIP_CD) && {src.PHRMCY_ADDR_ZIP_CD} != PHRMCY_ADDR_ZIP_CD,",
				"     !isNull(PHRMCY_ADDR_ZIP_CD) && {src.PHRMCY_ADDR_ZIP_CD} != PHRMCY_ADDR_ZIP_CD,",
				"     disjoint: false) ~> split1@(NEW, UPDATE, INSERT, NOCHANGE)",
				"split1@NEW derive(IsActive = 1) ~> derivedColumn1",
				"split1@UPDATE derive(IsNull = 0) ~> derivedColumn2",
				"split1@INSERT derive(IsActive = 1) ~> derivedColumn3",
				"derivedColumn2 alterRow(updateIf(true())) ~> alterRow1",
				"split1@NOCHANGE sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     mapColumn(",
				"          PHRMCY_NAT_PROV_ID_NBR = {src.PHRMCY_NAT_PROV_ID_NBR},",
				"          PHRMCY_NCPDP_NBR = {src.PHRMCY_NCPDP_NBR},",
				"          PTNT_CD = {src.PTNT_CD},",
				"          PSCB_FIRST_NM = {src.PSCB_FIRST_NM},",
				"          PSCB_LAST_NM = {src.PSCB_LAST_NM},",
				"          LANG_CD = {src.LANG_CD},",
				"          DEAL_ID = split1@NOCHANGE@{src.DEAL_ID},",
				"          PHRMCY_NM = {src.PHRMCY_NM},",
				"          PHRMCY_ST_ADDR_LINE1_TXT = {src.PHRMCY_ST_ADDR_LINE1_TXT},",
				"          PHRMCY_ADDR_ZIP_CD = {src.PHRMCY_ADDR_ZIP_CD},",
				"          PHRMCY_ADDR_CITY_NM = {src.PHRMCY_ADDR_CITY_NM},",
				"          PHRMCY_ADDR_ST_CD = {src.PHRMCY_ADDR_ST_CD},",
				"          PHRMCY_ADDR_ST_NAME = {src.PHRMCY_ADDR_ST_NAME},",
				"          PHRMCY_ADDR_ZNE_CD = {src.PHRMCY_ADDR_ZNE_CD},",
				"          PHRMCY_ADDR_ZNE_NM = {src.PHRMCY_ADDR_ZNE_NM},",
				"          PHRMCY_SYS_IVR_DTA_STRT_DT = {src.PHRMCY_SYS_IVR_DTA_STRT_DT},",
				"          deal_id = split1@NOCHANGE@{src.deal_id},",
				"          deal_nbr = {src.deal_nbr},",
				"          LANG_ID = {src.LANG_ID},",
				"          LANG_DESC = {src.LANG_DESC},",
				"          PTNT_KEY,",
				"          PTNT_ID,",
				"          PTNT_CD,",
				"          PHRMCY_NCPDPNBR,",
				"          PHRMCY_NAT_PROV_ID_NBR,",
				"          PSCB_FIRST_NM,",
				"          PSCB_LAST_NM,",
				"          PHRMCY_NM,",
				"          PHRMCY_ADDR_CITY_NM,",
				"          PHRMCY_ADDR_ST_NM,",
				"          PHRMCY_ADDR_ZNE_NM,",
				"          PHRMCY_ADDR_ZIP_CD,",
				"          PSCB_EMAIL_ID,",
				"          PHRMCY_SYS_IVR_DTA_STRT_DT,",
				"          PHRMCY_SYS_IVR_DTA_STRT_QTY,",
				"          PHRMCY_SYS_IVR_DTA_STRT_YR,",
				"          PHRMCY_AGE,",
				"          DEAL_ID,",
				"          DEAL_TYPE_CD,",
				"          LANG_CD,",
				"          LANG_DESC,",
				"          RCD_CRT_TMS,",
				"          RCD_MOD_TMS,",
				"          START_DATE,",
				"          END_DATE,",
				"          DEAL_NUMBER",
				"     )) ~> sink1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     mapColumn(",
				"          PHRMCY_NAT_PROV_ID_NBR = {src.PHRMCY_NAT_PROV_ID_NBR},",
				"          PHRMCY_NCPDP_NBR = {src.PHRMCY_NCPDP_NBR},",
				"          PTNT_CD = {src.PTNT_CD},",
				"          PSCB_FIRST_NM = {src.PSCB_FIRST_NM},",
				"          PSCB_LAST_NM = {src.PSCB_LAST_NM},",
				"          LANG_CD = {src.LANG_CD},",
				"          DEAL_ID = split1@NEW@{src.DEAL_ID},",
				"          PHRMCY_NM = {src.PHRMCY_NM},",
				"          PHRMCY_ST_ADDR_LINE1_TXT = {src.PHRMCY_ST_ADDR_LINE1_TXT},",
				"          PHRMCY_ADDR_ZIP_CD = {src.PHRMCY_ADDR_ZIP_CD},",
				"          PHRMCY_ADDR_CITY_NM = {src.PHRMCY_ADDR_CITY_NM},",
				"          PHRMCY_ADDR_ST_CD = {src.PHRMCY_ADDR_ST_CD},",
				"          PHRMCY_ADDR_ST_NAME = {src.PHRMCY_ADDR_ST_NAME},",
				"          PHRMCY_ADDR_ZNE_CD = {src.PHRMCY_ADDR_ZNE_CD},",
				"          PHRMCY_ADDR_ZNE_NM = {src.PHRMCY_ADDR_ZNE_NM},",
				"          PHRMCY_SYS_IVR_DTA_STRT_DT = {src.PHRMCY_SYS_IVR_DTA_STRT_DT},",
				"          deal_id = split1@NEW@{src.deal_id},",
				"          deal_nbr = {src.deal_nbr},",
				"          LANG_ID = {src.LANG_ID},",
				"          LANG_DESC = {src.LANG_DESC},",
				"          PTNT_KEY,",
				"          PTNT_ID,",
				"          PTNT_CD,",
				"          PHRMCY_NCPDPNBR,",
				"          PHRMCY_NAT_PROV_ID_NBR,",
				"          PSCB_FIRST_NM,",
				"          PSCB_LAST_NM,",
				"          PHRMCY_NM,",
				"          PHRMCY_ADDR_CITY_NM,",
				"          PHRMCY_ADDR_ST_NM,",
				"          PHRMCY_ADDR_ZNE_NM,",
				"          PHRMCY_ADDR_ZIP_CD,",
				"          PSCB_EMAIL_ID,",
				"          PHRMCY_SYS_IVR_DTA_STRT_DT,",
				"          PHRMCY_SYS_IVR_DTA_STRT_QTY,",
				"          PHRMCY_SYS_IVR_DTA_STRT_YR,",
				"          PHRMCY_AGE,",
				"          DEAL_ID,",
				"          DEAL_TYPE_CD,",
				"          LANG_CD,",
				"          LANG_DESC,",
				"          RCD_CRT_TMS,",
				"          RCD_MOD_TMS,",
				"          START_DATE,",
				"          END_DATE,",
				"          DEAL_NUMBER,",
				"          IsActive",
				"     )) ~> sink2",
				"alterRow1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     mapColumn(",
				"          PHRMCY_NAT_PROV_ID_NBR = {src.PHRMCY_NAT_PROV_ID_NBR},",
				"          PHRMCY_NCPDP_NBR = {src.PHRMCY_NCPDP_NBR},",
				"          PTNT_CD = {src.PTNT_CD},",
				"          PSCB_FIRST_NM = {src.PSCB_FIRST_NM},",
				"          PSCB_LAST_NM = {src.PSCB_LAST_NM},",
				"          LANG_CD = {src.LANG_CD},",
				"          DEAL_ID = split1@UPDATE@{src.DEAL_ID},",
				"          PHRMCY_NM = {src.PHRMCY_NM},",
				"          PHRMCY_ST_ADDR_LINE1_TXT = {src.PHRMCY_ST_ADDR_LINE1_TXT},",
				"          PHRMCY_ADDR_ZIP_CD = {src.PHRMCY_ADDR_ZIP_CD},",
				"          PHRMCY_ADDR_CITY_NM = {src.PHRMCY_ADDR_CITY_NM},",
				"          PHRMCY_ADDR_ST_CD = {src.PHRMCY_ADDR_ST_CD},",
				"          PHRMCY_ADDR_ST_NAME = {src.PHRMCY_ADDR_ST_NAME},",
				"          PHRMCY_ADDR_ZNE_CD = {src.PHRMCY_ADDR_ZNE_CD},",
				"          PHRMCY_ADDR_ZNE_NM = {src.PHRMCY_ADDR_ZNE_NM},",
				"          PHRMCY_SYS_IVR_DTA_STRT_DT = {src.PHRMCY_SYS_IVR_DTA_STRT_DT},",
				"          deal_id = split1@UPDATE@{src.deal_id},",
				"          deal_nbr = {src.deal_nbr},",
				"          LANG_ID = {src.LANG_ID},",
				"          LANG_DESC = {src.LANG_DESC},",
				"          PTNT_KEY,",
				"          PTNT_ID,",
				"          PTNT_CD,",
				"          PHRMCY_NCPDPNBR,",
				"          PHRMCY_NAT_PROV_ID_NBR,",
				"          PSCB_FIRST_NM,",
				"          PSCB_LAST_NM,",
				"          PHRMCY_NM,",
				"          PHRMCY_ADDR_CITY_NM,",
				"          PHRMCY_ADDR_ST_NM,",
				"          PHRMCY_ADDR_ZNE_NM,",
				"          PHRMCY_ADDR_ZIP_CD,",
				"          PSCB_EMAIL_ID,",
				"          PHRMCY_SYS_IVR_DTA_STRT_DT,",
				"          PHRMCY_SYS_IVR_DTA_STRT_QTY,",
				"          PHRMCY_SYS_IVR_DTA_STRT_YR,",
				"          PHRMCY_AGE,",
				"          DEAL_ID,",
				"          DEAL_TYPE_CD,",
				"          LANG_CD,",
				"          LANG_DESC,",
				"          RCD_CRT_TMS,",
				"          RCD_MOD_TMS,",
				"          START_DATE,",
				"          END_DATE,",
				"          DEAL_NUMBER,",
				"          IsNull",
				"     )) ~> sink3",
				"derivedColumn3 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     mapColumn(",
				"          PHRMCY_NAT_PROV_ID_NBR = {src.PHRMCY_NAT_PROV_ID_NBR},",
				"          PHRMCY_NCPDP_NBR = {src.PHRMCY_NCPDP_NBR},",
				"          PTNT_CD = {src.PTNT_CD},",
				"          PSCB_FIRST_NM = {src.PSCB_FIRST_NM},",
				"          PSCB_LAST_NM = {src.PSCB_LAST_NM},",
				"          LANG_CD = {src.LANG_CD},",
				"          DEAL_ID = split1@INSERT@{src.DEAL_ID},",
				"          PHRMCY_NM = {src.PHRMCY_NM},",
				"          PHRMCY_ST_ADDR_LINE1_TXT = {src.PHRMCY_ST_ADDR_LINE1_TXT},",
				"          PHRMCY_ADDR_ZIP_CD = {src.PHRMCY_ADDR_ZIP_CD},",
				"          PHRMCY_ADDR_CITY_NM = {src.PHRMCY_ADDR_CITY_NM},",
				"          PHRMCY_ADDR_ST_CD = {src.PHRMCY_ADDR_ST_CD},",
				"          PHRMCY_ADDR_ST_NAME = {src.PHRMCY_ADDR_ST_NAME},",

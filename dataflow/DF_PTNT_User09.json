{
	"name": "DF_PTNT_User09",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_SQL_Source_Table",
						"type": "DatasetReference"
					},
					"name": "SRCPHRMCY"
				},
				{
					"dataset": {
						"referenceName": "DS_SQL_Source_Table",
						"type": "DatasetReference"
					},
					"name": "STATUS"
				},
				{
					"dataset": {
						"referenceName": "DS_SQL_Source_Table",
						"type": "DatasetReference"
					},
					"name": "LULANGUAGE"
				},
				{
					"dataset": {
						"referenceName": "DS_Target_SQl",
						"type": "DatasetReference"
					},
					"name": "Target"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DS_Target_SQl",
						"type": "DatasetReference"
					},
					"name": "DIMPTNT"
				},
				{
					"name": "Dpint"
				},
				{
					"dataset": {
						"referenceName": "DS_Target_SQl",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "join1"
				},
				{
					"name": "join2"
				},
				{
					"name": "select1"
				},
				{
					"name": "derivedColumn1"
				},
				{
					"name": "select2"
				},
				{
					"name": "join3"
				},
				{
					"name": "split1"
				},
				{
					"name": "derivedColumn2"
				},
				{
					"name": "select3"
				},
				{
					"name": "derivedColumn3"
				},
				{
					"name": "select4"
				},
				{
					"name": "derivedColumn4"
				},
				{
					"name": "derivedColumn5"
				},
				{
					"name": "alterRow1"
				},
				{
					"name": "derivedColumn6"
				},
				{
					"name": "alterRow2"
				}
			],
			"scriptLines": [
				"source(output(",
				"          PHRMCY_NAT_PROV_ID_NBR as string,",
				"          PHRMCY_NCPDP_NBR as double,",
				"          PTNT_CD as string,",
				"          PSCB_FIRST_NM as string,",
				"          PSCB_LAST_NM as string,",
				"          LANG_CD as string,",
				"          DEAL_ID as string,",
				"          PHRMCY_NM as string,",
				"          PHRMCY_ST_ADDR_LINE1_TXT as string,",
				"          PHRMCY_ADDR_ZIP_CD as double,",
				"          PHRMCY_ADDR_CITY_NM as string,",
				"          PHRMCY_ADDR_ST_CD as string,",
				"          PHRMCY_ADDR_ST_NAME as string,",
				"          PHRMCY_ADDR_ZNE_CD as string,",
				"          PHRMCY_ADDR_ZNE_NM as string,",
				"          PHRMCY_SYS_IVR_DTA_STRT_DT as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> SRCPHRMCY",
				"source(output(",
				"          deal_id as string,",
				"          deal_nbr as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> STATUS",
				"source(output(",
				"          LANG_ID as integer,",
				"          LANG_CD as string,",
				"          LANG_DESC as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> LULANGUAGE",
				"source(output(",
				"          PINT_KEY as integer,",
				"          PTNT_ID as integer,",
				"          PTNT_CD as string,",
				"          PHRMCY_NCPDP_NBR as integer,",
				"          PHRMCY_NAT_PROV_ID_NBR as string,",
				"          PSCB_FIRST_NM as string,",
				"          PSCB_LAST_NM as string,",
				"          PHRMCY_NM as string,",
				"          PHRMCY_ADDR_CITY_NM as string,",
				"          PHRMCY_ADDR_ST_NM as string,",
				"          PHRMCY_ADDR_ZNE_NM as string,",
				"          PHRMCY_ADDR_ZIP_CD as string,",
				"          PSCB_EMAIL_ID as string,",
				"          PHRMCY_SYS_IVR_DTA_STRT_DT as string,",
				"          PHRMCY_SYS_IVR_DTA_STRT_QTR as string,",
				"          PHRMCY_SYS_IVR_DTA_STRT_YR as string,",
				"          PHRMCY_AGE as integer,",
				"          DEAL_ID as string,",
				"          DEAL_TYPE_CD as string,",
				"          DEAL_NUMBER as string,",
				"          LANG_CD as string,",
				"          LANG_DESC as string,",
				"          RCD_CRT_TMS as timestamp,",
				"          RCD_MOD_TMS as timestamp,",
				"          START_DATE as timestamp,",
				"          END_DATE as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> Target",
				"SRCPHRMCY, STATUS join(SRCPHRMCY@DEAL_ID == STATUS@deal_id,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join1",
				"join1, LULANGUAGE join(SRCPHRMCY@LANG_CD == LULANGUAGE@LANG_CD,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join2",
				"join2 select(mapColumn(",
				"          PHRMCY_NAT_PROV_ID_NBR,",
				"          PHRMCY_NCPDP_NBR,",
				"          PTNT_CD,",
				"          PSCB_FIRST_NM,",
				"          PSCB_LAST_NM,",
				"          PHRMCY_NM,",
				"          PHRMCY_ADDR_ZIP_CD,",
				"          PHRMCY_ADDR_CITY_NM,",
				"          PHRMCY_ADDR_ST_CD,",
				"          PHRMCY_ADDR_ST_NAME,",
				"          PHRMCY_ADDR_ZNE_NM,",
				"          PHRMCY_SYS_IVR_DTA_STRT_DT,",
				"          deal_id = STATUS@deal_id,",
				"          deal_nbr,",
				"          LANG_ID,",
				"          LANG_CD = LULANGUAGE@LANG_CD,",
				"          LANG_DESC,",
				"          src_deal_id = SRCPHRMCY@DEAL_ID",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 derive(PINT_ID = toInteger(split(PTNT_CD, '_')[0]),",
				"          PTNT_CD = split(PTNT_CD, '_')[1],",
				"          PHRMCY_NAT_PROV_ID_NBR = iif(\r",
				"    isNull(PHRMCY_NAT_PROV_ID_NBR),'UNK',\r",
				"    PHRMCY_NAT_PROV_ID_NBR\r",
				"),",
				"          PHRMCY_NM = replace(replace(replace(replace(PHRMCY_NM,'-',' '),'&',' '),',',' '),\"'''\",' '),",
				"          PHRMCY_ADDR_CITY_NM = iif(\r",
				"    PHRMCY_ADDR_CITY_NM==' ',\r",
				"    concat(left(PHRMCY_ADDR_CITY_NM,1),left(split(PHRMCY_ADDR_CITY_NM,' ')[1],1)),\r",
				"    left(PHRMCY_ADDR_CITY_NM,3)\r",
				"),",
				"          PHRMCY_ADDR_ST_NM = initCap(PHRMCY_ADDR_ST_NAME),",
				"          PHRMCY_ADDR_ZNE_NM = initCap(PHRMCY_ADDR_ZNE_NM),",
				"          PHRMCY_ADDR_ZIP_CD = iif (\r",
				"    length(toString(PHRMCY_ADDR_ZIP_CD))<5,lpad(toString(PHRMCY_ADDR_ZIP_CD),5,'0'),\r",
				"    left(toString(PHRMCY_ADDR_ZIP_CD),5)\r",
				"),",
				"          PSCB_EMAIL_ID = concat(toString(length(PSCB_FIRST_NM)/2),'',left(PSCB_LAST_NM,1),'@UN.com'),",
				"          PHRMCY_SYS_IVR_DTA_STRT_DT = toString(toDate(PHRMCY_SYS_IVR_DTA_STRT_DT),'dd-MMM-yyyy'),",
				"          PHRMCY_SYS_IVR_DTA_STRT_QTR = toString(concat('Q1',toString(year(toDate(PHRMCY_SYS_IVR_DTA_STRT_DT))))),",
				"          PHRMCY_SYS_IVR_DTA_STRT_YR = toString(year(toDate(PHRMCY_SYS_IVR_DTA_STRT_DT))),",
				"          PHRMCY_AGE = toString(year(currentDate()-(PHRMCY_SYS_IVR_DTA_STRT_DT))),",
				"          DEAL_ID = deal_id\r",
				",",
				"          DEAL_TYPE_CD = left(deal_nbr,2),",
				"          DEAL_NUMBER = substring(deal_nbr,3,length(deal_nbr)-2),",
				"          RCD_CRT_TMS = currentDate(),",
				"          PTNT_ID = PTNT_CD,",
				"          PHRMCY_NCPDP_NBR = PHRMCY_NCPDP_NBR,",
				"          PSCB_FIRST_NM = PSCB_FIRST_NM,",
				"          PSCB_LAST_NM = PSCB_LAST_NM,",
				"          LANG_CD = LANG_CD,",
				"          LANG_DESC = LANG_DESC,",
				"          RCD_MOD_TMS = ERROR_FUNCTION('')) ~> derivedColumn1",
				"derivedColumn1 select(mapColumn(",
				"          PHRMCY_NAT_PROV_ID_NBR,",
				"          PHRMCY_NCPDP_NBR,",
				"          PTNT_CD,",
				"          PSCB_FIRST_NM,",
				"          PSCB_LAST_NM,",
				"          PHRMCY_NM,",
				"          PHRMCY_ADDR_ZIP_CD,",
				"          PHRMCY_ADDR_CITY_NM,",
				"          PHRMCY_ADDR_ST_CD,",
				"          PHRMCY_ADDR_ST_NAME,",
				"          PHRMCY_ADDR_ZNE_NM,",
				"          PHRMCY_SYS_IVR_DTA_STRT_DT,",
				"          deal_id = select1@deal_id,",
				"          deal_nbr,",
				"          LANG_ID,",
				"          LANG_CD,",
				"          LANG_DESC,",
				"          src_deal_id,",
				"          PINT_ID,",
				"          PHRMCY_ADDR_ST_NM,",
				"          PSCB_EMAIL_ID,",
				"          PHRMCY_SYS_IVR_DTA_STRT_QTR,",
				"          PHRMCY_SYS_IVR_DTA_STRT_YR,",
				"          PHRMCY_AGE,",
				"          DEAL_ID = derivedColumn1@DEAL_ID,",
				"          DEAL_TYPE_CD,",
				"          DEAL_NUMBER,",
				"          RCD_CRT_TMS,",
				"          RCD_MOD_TMS",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select2",
				"select4, select3 join(PINT_ID == t_PTNT_ID,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join3",
				"join3 split(isNull(t_PTNT_ID),",
				"     PINT_ID==t_PTNT_ID&&SourceHash!=TargetHash,",
				"     disjoint: false) ~> split1@(newinsert, existing)",
				"Target derive(TargetHash = md5(PHRMCY_ADDR_ZIP_CD)) ~> derivedColumn2",
				"derivedColumn2 select(mapColumn(",
				"          t_PINT_KEY = PINT_KEY,",
				"          t_PTNT_ID = PTNT_ID,",
				"          t_PTNT_CD = PTNT_CD,",
				"          t_PHRMCY_NCPDP_NBR = PHRMCY_NCPDP_NBR,",
				"          t_PHRMCY_NAT_PROV_ID_NBR = PHRMCY_NAT_PROV_ID_NBR,",
				"          PSCB_FIRST_NM,",
				"          PSCB_LAST_NM,",
				"          t_PHRMCY_NM = PHRMCY_NM,",
				"          t_PHRMCY_ADDR_CITY_NM = PHRMCY_ADDR_CITY_NM,",
				"          t_PHRMCY_ADDR_ST_NM = PHRMCY_ADDR_ST_NM,",
				"          t_PHRMCY_ADDR_ZNE_NM = PHRMCY_ADDR_ZNE_NM,",
				"          t_PHRMCY_ADDR_ZIP_CD = PHRMCY_ADDR_ZIP_CD,",
				"          t_PSCB_EMAIL_ID = PSCB_EMAIL_ID,",
				"          t_PHRMCY_SYS_IVR_DTA_STRT_DT = PHRMCY_SYS_IVR_DTA_STRT_DT,",
				"          t_PHRMCY_SYS_IVR_DTA_STRT_QTR = PHRMCY_SYS_IVR_DTA_STRT_QTR,",
				"          t_PHRMCY_SYS_IVR_DTA_STRT_YR = PHRMCY_SYS_IVR_DTA_STRT_YR,",
				"          t_PHRMCY_AGE = PHRMCY_AGE,",
				"          t_DEAL_ID = DEAL_ID,",
				"          t_DEAL_TYPE_CD = DEAL_TYPE_CD,",
				"          t_DEAL_NUMBER = DEAL_NUMBER,",
				"          t_LANG_CD = LANG_CD,",
				"          t_LANG_DESC = LANG_DESC,",
				"          t_RCD_CRT_TMS = RCD_CRT_TMS,",
				"          t_RCD_MOD_TMS = RCD_MOD_TMS,",
				"          START_DATE,",
				"          END_DATE,",
				"          TargetHash",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select3",
				"select2 derive(SourceHash = md5(PHRMCY_ADDR_ZIP_CD)) ~> derivedColumn3",
				"derivedColumn3 select(mapColumn(",
				"          PHRMCY_NAT_PROV_ID_NBR,",
				"          PHRMCY_NCPDP_NBR,",
				"          PTNT_CD,",
				"          PSCB_FIRST_NM,",
				"          PSCB_LAST_NM,",
				"          PHRMCY_NM,",
				"          PHRMCY_ADDR_ZIP_CD,",
				"          PHRMCY_ADDR_CITY_NM,",
				"          PHRMCY_ADDR_ST_CD,",
				"          PHRMCY_ADDR_ST_NAME,",
				"          PHRMCY_ADDR_ZNE_NM,",
				"          PHRMCY_SYS_IVR_DTA_STRT_DT,",
				"          deal_id = select2@deal_id,",
				"          deal_nbr,",
				"          LANG_ID,",
				"          LANG_CD,",
				"          LANG_DESC,",
				"          src_deal_id,",
				"          PINT_ID,",
				"          PHRMCY_ADDR_ST_NM,",
				"          PSCB_EMAIL_ID,",
				"          PHRMCY_SYS_IVR_DTA_STRT_QTR,",
				"          PHRMCY_SYS_IVR_DTA_STRT_YR,",
				"          PHRMCY_AGE,",
				"          DEAL_ID = select2@DEAL_ID,",
				"          DEAL_TYPE_CD,",
				"          DEAL_NUMBER,",
				"          RCD_CRT_TMS,",
				"          RCD_MOD_TMS,",
				"          SourceHash",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select4",
				"split1@newinsert derive(StartDate = currentDate()) ~> derivedColumn4",
				"split1@existing derive(END_DATE = currentDate()) ~> derivedColumn5",
				"derivedColumn5 alterRow(updateIf(1==1)) ~> alterRow1",
				"split1@existing derive(StartDate = currentDate()) ~> derivedColumn6",
				"derivedColumn6 alterRow(insertIf(1==1)) ~> alterRow2",
				"derivedColumn4 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     saveOrder: 2) ~> DIMPTNT",
				"alterRow1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     saveOrder: 1) ~> Dpint",
				"alterRow2 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     saveOrder: 3) ~> sink1"
			]
		}
	}
}
{
	"name": "DF_SCD2_DIM_PTNT",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_SQL_SERVER",
						"type": "DatasetReference"
					},
					"name": "srcphrmcy"
				},
				{
					"dataset": {
						"referenceName": "DS_SQL_SERVER",
						"type": "DatasetReference"
					},
					"name": "status"
				},
				{
					"dataset": {
						"referenceName": "DS_SQL_SERVER",
						"type": "DatasetReference"
					},
					"name": "lulanguage"
				},
				{
					"dataset": {
						"referenceName": "DS_SQL_SERVER",
						"type": "DatasetReference"
					},
					"name": "dimptnt"
				}
			],
			"sinks": [],
			"transformations": [
				{
					"name": "srcphrmacyjoinstatus"
				},
				{
					"name": "srcphrmacyjoinlulanguage"
				},
				{
					"name": "requiredcolumn"
				},
				{
					"name": "matchingcolumns"
				},
				{
					"name": "derivedColumn1"
				},
				{
					"name": "split"
				},
				{
					"name": "derivedColumn2"
				}
			],
			"scriptLines": [
				"source(output(",
				"          PHRMCY_NAT_PROV_ID_NBR as string,",
				"          PHRMCY_NCPDP_NBR as double,",
				"          PTNT_CD as string,",
				"          PSCB_FIRST_NM as string,",
				"          PSCB_LAST_NM as string,",
				"          LANG_CD as string,",
				"          DEAL_ID as string,",
				"          PHRMCY_NM as string,",
				"          PHRMCY_ST_ADDR_LINE1_TXT as string,",
				"          PHRMCY_ADDR_ZIP_CD as double,",
				"          PHRMCY_ADDR_CITY_NM as string,",
				"          PHRMCY_ADDR_ST_CD as string,",
				"          PHRMCY_ADDR_ST_NAME as string,",
				"          PHRMCY_ADDR_ZNE_CD as string,",
				"          PHRMCY_ADDR_ZNE_NM as string,",
				"          PHRMCY_SYS_IVR_DTA_STRT_DT as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> srcphrmcy",
				"source(output(",
				"          deal_id as string,",
				"          deal_nbr as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> status",
				"source(output(",
				"          LANG_ID as integer,",
				"          LANG_CD as string,",
				"          LANG_DESC as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> lulanguage",
				"source(output(",
				"          PTNT_KEY as integer,",
				"          PTNT_ID as integer,",
				"          PTNT_CD as string,",
				"          PHRMCY_NCPDR_NBR as integer,",
				"          PHRMCY_NAT_PROV_ID_NBR as string,",
				"          PSCB_FIRST_NM as string,",
				"          PSCB_LAST_NM as string,",
				"          PHRMCY_NM as string,",
				"          PHRMCY_ADDR_CITY_NM as string,",
				"          PHRMCY_ADDR_ST_NM as string,",
				"          PHRMCY_ADDR_ZNE_NM as string,",
				"          PHRMCY_ADDR_ZIP_CD as string,",
				"          PSCB_EMAIL_ID as string,",
				"          PHRMCY_SYS_IVR_DTA_STRT_DT as string,",
				"          PHRMCY_SYS_IVR_DTA_STRT_QTR as string,",
				"          PHRMCY_SYS_IVR_DTA_STRT_YR as string,",
				"          PHRMCY_AGE as integer,",
				"          DEAL_ID as string,",
				"          DEAL_TYPE_CD as string,",
				"          DEAL_NUMBER as string,",
				"          LANG_CD as string,",
				"          LANG_DESC as string,",
				"          RCD_CRT_TMS as timestamp,",
				"          RCD_MOD_TMS as timestamp,",
				"          START_DATE as timestamp,",
				"          END_DATE as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> dimptnt",
				"srcphrmcy, status join(srcphrmcy@DEAL_ID == status@deal_id,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> srcphrmacyjoinstatus",
				"srcphrmacyjoinstatus, lulanguage join(srcphrmcy@LANG_CD == lulanguage@LANG_CD,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> srcphrmacyjoinlulanguage",
				"srcphrmacyjoinlulanguage select(mapColumn(",
				"          PHRMCY_NAT_PROV_ID_NBR,",
				"          PHRMCY_NCPDP_NBR,",
				"          PTNT_CD,",
				"          PSCB_FIRST_NM,",
				"          PSCB_LAST_NM,",
				"          PHRMCY_NM,",
				"          PHRMCY_ADDR_ZIP_CD,",
				"          PHRMCY_ADDR_CITY_NM,",
				"          PHRMCY_ADDR_ST_NAME,",
				"          PHRMCY_ADDR_ZNE_NM,",
				"          PHRMCY_SYS_IVR_DTA_STRT_DT,",
				"          deal_id = status@deal_id,",
				"          deal_nbr,",
				"          LANG_CD = lulanguage@LANG_CD,",
				"          LANG_DESC",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> requiredcolumn",
				"derivedColumn1, dimptnt lookup(key == dimptnt@PTNT_CD,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> matchingcolumns",
				"requiredcolumn derive(PHRMCY_ADDR_ZIP_CD = toString(PHRMCY_ADDR_ZIP_CD),",
				"          key = right(PTNT_CD, 4),",
				"          each(match(true()), concat('src', $$) = $$)) ~> derivedColumn1",
				"matchingcolumns split(isNull(PTNT_KEY),",
				"     (requiredcolumn@PTNT_CD==dimptnt@PTNT_CD)&&(derivedColumn1@PHRMCY_ADDR_ZIP_CD!=dimptnt@PHRMCY_ADDR_ZIP_CD),",
				"     disjoint: false) ~> split@(insert, Update)",
				"split@insert derive(srcPTNT_ID = left(srcPTNT_CD,locate(srcPTNT_CD,'-')),",
				"          srcPTNT_CD = right(srcPTNT_CD,4),",
				"          srcPHRMCY_NAT_PROV_ID_NBR = iifNull(srcPHRMCY_NAT_PROV_ID_NBR, 'UNK'),",
				"          srcPHRMCY_NM = replace(srcPHRMCY_NM, '-', ''),",
				"          srcPHRMCY_ADDR_CITY_NM = left(srcPHRMCY_ADDR_CITY_NM,3),",
				"          srcPHRMCY_ADDR_ST_NAME = initCap(srcPHRMCY_ADDR_ST_NAME),",
				"          srcPHRMCY_ADDR_ZNE_NM = initCap(srcPHRMCY_ADDR_ZNE_NM),",
				"          srcPHRMCY_ADDR_ZIP_CD = lpad(toString(srcPHRMCY_ADDR_ZIP_CD), 5, '0'),",
				"          srcPSCB_EMAIL = concat(left(srcPSCB_FIRST_NM,length(srcPSCB_FIRST_NM)/2),'@UN.com'),",
				"          src_date = toDate(srcPHRMCY_SYS_IVR_DTA_STRT_DT),",
				"          src_qtr = concat('Q1', '2001'),",
				"          srcyear = 2001,",
				"          srcage = 30,",
				"          srcdeal_id = iifNull(srcdeal_id, srcdeal_id, srcdeal_nbr),",
				"          src_deal_cd = left('srcdeal_nbr',2),",
				"          srcdealnbr = substring(srcdeal_nbr, 2)) ~> derivedColumn2"
			]
		}
	}
}
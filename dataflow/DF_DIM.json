{
	"name": "DF_DIM",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_SOURCE",
						"type": "DatasetReference"
					},
					"name": "SRCPHRMCY"
				},
				{
					"dataset": {
						"referenceName": "DS_SOURCE",
						"type": "DatasetReference"
					},
					"name": "STATUS"
				},
				{
					"dataset": {
						"referenceName": "DS_SOURCE",
						"type": "DatasetReference"
					},
					"name": "LULANGUAGE"
				},
				{
					"dataset": {
						"referenceName": "DS_TARGET",
						"type": "DatasetReference"
					},
					"name": "TARGET"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DS_TARGET",
						"type": "DatasetReference"
					},
					"name": "sink1"
				},
				{
					"dataset": {
						"referenceName": "DS_TARGET",
						"type": "DatasetReference"
					},
					"name": "sink2"
				}
			],
			"transformations": [
				{
					"name": "PHRMCYSTATUS"
				},
				{
					"name": "PHRMCYSTATUSLULANG"
				},
				{
					"name": "hashing"
				},
				{
					"name": "hasing"
				},
				{
					"name": "derivedColumn1"
				},
				{
					"name": "exists1"
				},
				{
					"name": "derivedColumn2"
				},
				{
					"name": "select1"
				},
				{
					"name": "exists2"
				},
				{
					"name": "exists3"
				},
				{
					"name": "derivedColumn3"
				},
				{
					"name": "alterRow1"
				},
				{
					"name": "select2"
				}
			],
			"scriptLines": [
				"source(output(",
				"          PHRMCY_NAT_PROV_ID_NBR as string,",
				"          PHRMCY_NCPDP_NBR as double,",
				"          PTNT_CD as string,",
				"          PSCB_FIRST_NM as string,",
				"          PSCB_LAST_NM as string,",
				"          LANG_CD as string,",
				"          DEAL_ID as string,",
				"          PHRMCY_NM as string,",
				"          PHRMCY_ST_ADDR_LINE1_TXT as string,",
				"          PHRMCY_ADDR_ZIP_CD as double,",
				"          PHRMCY_ADDR_CITY_NM as string,",
				"          PHRMCY_ADDR_ST_CD as string,",
				"          PHRMCY_ADDR_ST_NAME as string,",
				"          PHRMCY_ADDR_ZNE_CD as string,",
				"          PHRMCY_ADDR_ZNE_NM as string,",
				"          PHRMCY_SYS_IVR_DTA_STRT_DT as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> SRCPHRMCY",
				"source(output(",
				"          deal_id as string,",
				"          deal_nbr as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> STATUS",
				"source(output(",
				"          LANG_ID as integer,",
				"          LANG_CD as string,",
				"          LANG_DESC as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> LULANGUAGE",
				"source(output(",
				"          PTNT_KEY as integer,",
				"          PTNT_ID as integer,",
				"          PTNT_CD as string,",
				"          PHRMCY_NCPDF_NBR as integer,",
				"          PHRMCY_NAT_PROV_ID_NBR as string,",
				"          PSCB_FIRST_NM as string,",
				"          PSCB_LAST_NM as string,",
				"          PHRMCY_NM as string,",
				"          PHRMCY_ADDR_CITY_NM as string,",
				"          PHRMCY_ADDR_ST_NM as string,",
				"          PHRMCY_ADDR_ZNE_NM as string,",
				"          PHRMCY_ADDR_ZIP_CD as string,",
				"          PSCB_EMAIL_ID as string,",
				"          PHRMCY_SYS_IVR_DTA_STRT_DT as string,",
				"          PHRMCY_SYS_IVR_DTA_STRT_QTR as string,",
				"          PHRMCY_SYS_IVR_DTA_STRT_YR as string,",
				"          PHRMCY_AGE as integer,",
				"          DEAL_ID as string,",
				"          DEAL_TYPE_CD as string,",
				"          DEAL_NUMBER as string,",
				"          LANG_CD as string,",
				"          LANG_DESC as string,",
				"          RCD_CRT_TMS as timestamp,",
				"          RCD_MOD_TMS as timestamp,",
				"          START_DATE as timestamp,",
				"          END_DATE as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> TARGET",
				"SRCPHRMCY, STATUS join(SRCPHRMCY@DEAL_ID == STATUS@deal_id,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> PHRMCYSTATUS",
				"PHRMCYSTATUS, LULANGUAGE join(SRCPHRMCY@LANG_CD == LULANGUAGE@LANG_CD,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> PHRMCYSTATUSLULANG",
				"PHRMCYSTATUSLULANG derive(hash = md5(PHRMCY_NAT_PROV_ID_NBR,PHRMCY_NCPDP_NBR,PTNT_CD,PSCB_FIRST_NM,PSCB_LAST_NM,SRCPHRMCY@LANG_CD,SRCPHRMCY@DEAL_ID,PHRMCY_NM,PHRMCY_ST_ADDR_LINE1_TXT,PHRMCY_ADDR_ZIP_CD,PHRMCY_ADDR_CITY_NM,PHRMCY_ADDR_ST_CD,PHRMCY_ADDR_ST_NAME,PHRMCY_ADDR_ZNE_CD,PHRMCY_ADDR_ZNE_NM,PHRMCY_SYS_IVR_DTA_STRT_DT,STATUS@deal_id,deal_nbr,LANG_ID,LULANGUAGE@LANG_CD,LANG_DESC)) ~> hashing",
				"TARGET derive(hash = md5(PTNT_ID,PTNT_CD,PHRMCY_NCPDF_NBR,PSCB_FIRST_NM,PSCB_LAST_NM,PHRMCY_NM,PHRMCY_ADDR_CITY_NM,PHRMCY_ADDR_ST_NM,PHRMCY_ADDR_ZNE_NM,PHRMCY_ADDR_ZIP_CD,PSCB_EMAIL_ID,PHRMCY_SYS_IVR_DTA_STRT_DT,PHRMCY_SYS_IVR_DTA_STRT_QTR,PHRMCY_SYS_IVR_DTA_STRT_YR,PHRMCY_AGE,DEAL_ID,DEAL_TYPE_CD,DEAL_NUMBER,LANG_CD,LANG_DESC)) ~> hasing",
				"hashing derive(PTNT_ID = split(replace(PTNT_CD, \"_\", \"\"), \" \")[1],",
				"          PTNT_CD = right(PTNT_CD, 4),",
				"          PHRMCY_NAT_PROV_ID_NBR = iif(isNull(PHRMCY_NAT_PROV_ID_NBR), \"UNK\", PHRMCY_NAT_PROV_ID_NBR),",
				"          PHRMCY_NM = replace(PHRMCY_NM, \"-,&,,\", \"'\"),",
				"          PHRMCY_ADDR_ST_NAME = initCap(PHRMCY_ADDR_ST_NAME),",
				"          PHRMCY_ADDR_ZNE_NM = initCap(PHRMCY_ADDR_CITY_NM),",
				"          PHRMCY_ADDR_ZIP_CD = lpad('PHRMCY_ADDR_ZIP_CD', 5, '0'),",
				"          PSCB_EMAIL_ID = concat(PSCB_FIRST_NM, left(PSCB_LAST_NM, 1),\"@UN.com\"),",
				"          PHRMCY_SYS_IVR_DTA_STRT_DT = toString(PHRMCY_SYS_IVR_DTA_STRT_DT, 'dd-MMM-yyyy'),",
				"          PHRMCY_SYS_IVR_DTA_STRT_QTR = toString(PHRMCY_SYS_IVR_DTA_STRT_DT, 'QN-YYYY'),",
				"          PHRMCY_SYS_IVR_DTA_STRT_YR = year(PHRMCY_SYS_IVR_DTA_STRT_DT),",
				"          DEAL_TYPE_CD = left(deal_nbr, 2),",
				"          DEAL_NUMBER = dropLeft(deal_nbr,2),",
				"          RCD_MOD_TMS = currentDate(),",
				"          START_DATE = currentDate()) ~> derivedColumn1",
				"derivedColumn1, derivedColumn2 exists(hashing@hash == hasing@hash,",
				"     negate:true,",
				"     broadcast: 'auto')~> exists1",
				"hasing derive(PTNT_ID = split(replace(PTNT_CD, \"_\", \"\"), \" \")[1],",
				"          PTNT_CD = right(PTNT_CD, 4),",
				"          PHRMCY_NAT_PROV_ID_NBR = iif(isNull(PHRMCY_NAT_PROV_ID_NBR), \"UNK\", PHRMCY_NAT_PROV_ID_NBR),",
				"          PHRMCY_NM = replace(PHRMCY_NM, \"-,&,,\", \"'\"),",
				"          PHRMCY_ADDR_ST_NM = initCap(PHRMCY_ADDR_ST_NM),",
				"          PHRMCY_ADDR_ZNE_NM = initCap(PHRMCY_ADDR_CITY_NM),",
				"          PHRMCY_ADDR_ZIP_CD = lpad('PHRMCY_ADDR_ZIP_CD', 5, '0'),",
				"          PSCB_EMAIL_ID = concat(PSCB_FIRST_NM, left(PSCB_LAST_NM, 1),\"@UN.com\"),",
				"          PHRMCY_SYS_IVR_DTA_STRT_DT = toString(PHRMCY_SYS_IVR_DTA_STRT_DT, 'dd-MMM-yyyy')) ~> derivedColumn2",
				"exists1 select(mapColumn(",
				"          PTNT_ID,",
				"          PTNT_CD,",
				"          PHRMCY_NCPDP_NBR,",
				"          PHRMCY_NAT_PROV_ID_NBR,",
				"          PSCB_FIRST_NM,",
				"          PSCB_LAST_NM,",
				"          PHRMCY_NM,",
				"          PHRMCY_ADDR_CITY_NM,",
				"          PHRMCY_ADDR_ST_NAME,",
				"          PHRMCY_ADDR_ZNE_NM,",
				"          PHRMCY_ADDR_ZIP_CD,",
				"          PSCB_EMAIL_ID,",
				"          PHRMCY_SYS_IVR_DTA_STRT_DT,",
				"          PHRMCY_SYS_IVR_DTA_STRT_QTR,",
				"          PHRMCY_SYS_IVR_DTA_STRT_YR,",
				"          PHRMCY_AGE = PHRMCY_SYS_IVR_DTA_STRT_DT,",
				"          deal_id = STATUS@deal_id,",
				"          DEAL_TYPE_CD,",
				"          DEAL_NUMBER,",
				"          START_DATE = SRCPHRMCY@LANG_CD,",
				"          LANG_DESC,",
				"          RCD_MOD_TMS,",
				"          START_DATE",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"derivedColumn2, derivedColumn1 exists(derivedColumn2@PTNT_CD == derivedColumn1@PTNT_CD,",
				"     negate:false,",
				"     broadcast: 'auto')~> exists2",
				"exists2, derivedColumn1 exists(hasing@hash == hashing@hash,",
				"     negate:true,",
				"     broadcast: 'auto')~> exists3",
				"exists3 derive(END_DATE = currentDate()) ~> derivedColumn3",
				"derivedColumn3 alterRow(updateIf(1==1)) ~> alterRow1",
				"alterRow1 select(mapColumn(",
				"          PTNT_ID,",
				"          PTNT_CD,",
				"          PHRMCY_NCPDF_NBR,",
				"          PHRMCY_NAT_PROV_ID_NBR,",
				"          PSCB_FIRST_NM,",
				"          PSCB_LAST_NM,",
				"          PHRMCY_NM,",
				"          PHRMCY_ADDR_CITY_NM,",
				"          PHRMCY_ADDR_ST_NM,",
				"          PHRMCY_ADDR_ZNE_NM,",
				"          PHRMCY_ADDR_ZIP_CD,",
				"          PSCB_EMAIL_ID,",
				"          PHRMCY_SYS_IVR_DTA_STRT_DT,",
				"          PHRMCY_SYS_IVR_DTA_STRT_QTR,",
				"          PHRMCY_SYS_IVR_DTA_STRT_YR,",
				"          PHRMCY_AGE,",
				"          DEAL_ID,",
				"          DEAL_TYPE_CD,",
				"          DEAL_NUMBER,",
				"          LANG_CD,",
				"          LANG_DESC,",
				"          RCD_CRT_TMS,",
				"          RCD_MOD_TMS,",
				"          START_DATE,",
				"          END_DATE",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select2",
				"select1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     saveOrder: 2,",
				"     mapColumn(",
				"          PTNT_ID,",
				"          PTNT_CD,",
				"          PHRMCY_NCPDP_NBR,",
				"          PHRMCY_NAT_PROV_ID_NBR,",
				"          PSCB_FIRST_NM,",
				"          PSCB_LAST_NM,",
				"          PHRMCY_NM,",
				"          PHRMCY_ADDR_CITY_NM,",
				"          PHRMCY_ADDR_ST_NAME,",
				"          PHRMCY_ADDR_ZNE_NM,",
				"          PHRMCY_ADDR_ZIP_CD,",
				"          PSCB_EMAIL_ID,",
				"          PHRMCY_SYS_IVR_DTA_STRT_DT,",
				"          PHRMCY_SYS_IVR_DTA_STRT_QTR,",
				"          PHRMCY_SYS_IVR_DTA_STRT_YR,",
				"          deal_id,",
				"          DEAL_TYPE_CD,",
				"          DEAL_NUMBER,",
				"          START_DATE,",
				"          LANG_DESC,",
				"          RCD_MOD_TMS",
				"     )) ~> sink1",
				"select2 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:false,",
				"     updateable:true,",
				"     upsertable:false,",
				"     keys:['PTNT_ID'],",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     saveOrder: 1) ~> sink2"
			]
		}
	}
}
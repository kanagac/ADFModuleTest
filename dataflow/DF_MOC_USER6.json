{
	"name": "DF_MOC_USER6",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_SQL_SERVER_SRC_USER6",
						"type": "DatasetReference"
					},
					"name": "PHRMCY"
				},
				{
					"dataset": {
						"referenceName": "DS_SQL_SERVER_SRC_USER6",
						"type": "DatasetReference"
					},
					"name": "STATUS"
				},
				{
					"dataset": {
						"referenceName": "DS_SQL_SERVER_SRC_USER6",
						"type": "DatasetReference"
					},
					"name": "LANGUAGE"
				},
				{
					"dataset": {
						"referenceName": "DS_SQL_SERVER_TGT_USER6",
						"type": "DatasetReference"
					},
					"name": "DIMTGT"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DS_SQL_SERVER_TGT_USER6",
						"type": "DatasetReference"
					},
					"name": "tgt"
				}
			],
			"transformations": [
				{
					"name": "join1"
				},
				{
					"name": "join3"
				},
				{
					"name": "join4"
				},
				{
					"name": "SELECT"
				},
				{
					"name": "derivedColumn1"
				},
				{
					"name": "select1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          PHRMCY_NAT_PROV_ID_NBR as string,",
				"          PHRMCY_NCPDP_NBR as double,",
				"          PTNT_CD as string,",
				"          PSCB_FIRST_NM as string,",
				"          PSCB_LAST_NM as string,",
				"          LANG_CD as string,",
				"          DEAL_ID as string,",
				"          PHRMCY_NM as string,",
				"          PHRMCY_ST_ADDR_LINE1_TXT as string,",
				"          PHRMCY_ADDR_ZIP_CD as double,",
				"          PHRMCY_ADDR_CITY_NM as string,",
				"          PHRMCY_ADDR_ST_CD as string,",
				"          PHRMCY_ADDR_ST_NAME as string,",
				"          PHRMCY_ADDR_ZNE_CD as string,",
				"          PHRMCY_ADDR_ZNE_NM as string,",
				"          PHRMCY_SYS_IVR_DTA_STRT_DT as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> PHRMCY",
				"source(output(",
				"          deal_id as string,",
				"          deal_nbr as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> STATUS",
				"source(output(",
				"          LANG_ID as integer,",
				"          LANG_CD as string,",
				"          LANG_DESC as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> LANGUAGE",
				"source(output(",
				"          PTNT_KEY as integer,",
				"          PTNT_ID as integer,",
				"          PTNT_CD as string,",
				"          PHRMCY_NCPDP_NBR as integer,",
				"          PHRMCY_NAT_PROV_ID_NBR as string,",
				"          PSCB_FIRST_NM as string,",
				"          PSCB_LAST_NM as string,",
				"          PHRMCY_NM as string,",
				"          PHRMCY_ADDR_CITY_NM as string,",
				"          PHRMCY_ADDR_ST_NM as string,",
				"          PHRMCY_ADDR_ZNE_NM as string,",
				"          PHRMCY_ADDR_ZIP_CD as string,",
				"          PSCB_EMAIL_ID as string,",
				"          PHRMCY_SYS_IVR_DTA_STRT_DT as string,",
				"          PHRMCY_SYS_IVR_DTA_STRT_QTR as string,",
				"          PHRMCY_SYS_IVR_DTA_STRT_YR as string,",
				"          PHRMCY_AGE as integer,",
				"          DEAL_ID as string,",
				"          DEAL_TYPE_CD as string,",
				"          DEAL_NUMBER as string,",
				"          LANG_CD as string,",
				"          LANG_DESC as string,",
				"          RCD_CRT_TMS as timestamp,",
				"          RCD_MOD_TMS as timestamp,",
				"          START_DATE as timestamp,",
				"          END_DATE as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> DIMTGT",
				"PHRMCY, STATUS join(PHRMCY@DEAL_ID == STATUS@deal_id,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join1",
				"join1, LANGUAGE join(PHRMCY@LANG_CD == LANGUAGE@LANG_CD,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join3",
				"join3, DIMTGT join(STATUS@deal_id == DIMTGT@DEAL_ID,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join4",
				"join4 select(mapColumn(",
				"          PTNT_KEY,",
				"          PTNT_ID,",
				"          PTNT_CD = PHRMCY@PTNT_CD,",
				"          PHRMCY_NCPDP_NBR = PHRMCY@PHRMCY_NCPDP_NBR,",
				"          PHRMCY_NAT_PROV_ID_NBR = PHRMCY@PHRMCY_NAT_PROV_ID_NBR,",
				"          PSCB_FIRST_NM = PHRMCY@PSCB_FIRST_NM,",
				"          PSCB_LAST_NM = PHRMCY@PSCB_LAST_NM,",
				"          PHRMCY_NM = PHRMCY@PHRMCY_NM,",
				"          PHRMCY_ADDR_CITY_NM = PHRMCY@PHRMCY_ADDR_CITY_NM,",
				"          PHRMCY_ADDR_ST_NM,",
				"          PHRMCY_ADDR_ZNE_NM = PHRMCY@PHRMCY_ADDR_ZNE_NM,",
				"          PHRMCY_ADDR_ZIP_CD = PHRMCY@PHRMCY_ADDR_ZIP_CD,",
				"          PSCB_EMAIL_ID,",
				"          PHRMCY_SYS_IVR_DTA_STRT_DT = PHRMCY@PHRMCY_SYS_IVR_DTA_STRT_DT,",
				"          PHRMCY_SYS_IVR_DTA_STRT_QTR,",
				"          PHRMCY_SYS_IVR_DTA_STRT_YR,",
				"          PHRMCY_AGE,",
				"          DEAL_ID = STATUS@deal_id,",
				"          DEAL_TYPE_CD,",
				"          DEAL_NUMBER = deal_nbr,",
				"          LANG_CD = LANGUAGE@LANG_CD,",
				"          LANG_DESC = LANGUAGE@LANG_DESC,",
				"          RCD_CRT_TMS,",
				"          RCD_MOD_TMS,",
				"          START_DATE,",
				"          END_DATE,",
				"          PHRMCY_ADDR_ZNE_CD",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> SELECT",
				"SELECT derive(PTNT_CD = toString(substring(PTNT_CD, length(PTNT_CD)-4,4)),",
				"          PHRMCY_NAT_PROV_ID_NBR = iif(isNull(PHRMCY_NAT_PROV_ID_NBR), \"Unk\", \"PHRMCY_NAT_PROV_ID_NBR\"),",
				"          PTNT_ID = replace(PTNT_CD,\"_\",\" \"),",
				"          PHRMCY_NM = replace(replace(replace(PHRMCY_NM,\"-\",\" \"),\"&\",\" \"),\",\",\" \"),",
				"          PHRMCY_ADDR_ST_NM = initCap(PHRMCY_ADDR_ST_NM),",
				"          PHRMCY_ADDR_ZNE_NM = initCap(PHRMCY_ADDR_ZNE_NM),",
				"          PSCB_EMAIL_ID = concat(substring(PSCB_FIRST_NM,1,2),PSCB_LAST_NM,\"UN.com\"),",
				"          PHRMCY_SYS_IVR_DTA_STRT_DT = toString(toDate(PHRMCY_SYS_IVR_DTA_STRT_DT),\"dd-MMM-yyyy\"),",
				"          PHRMCY_SYS_IVR_DTA_STRT_QTR = toString(toDate(PHRMCY_SYS_IVR_DTA_STRT_DT),\"QN-yyyy\"),",
				"          PHRMCY_SYS_IVR_DTA_STRT_YR = toString(toDate(PHRMCY_SYS_IVR_DTA_STRT_DT),\"yyyy\"),",
				"          PHRMCY_AGE = monthsBetween(currentDate(),PHRMCY_SYS_IVR_DTA_STRT_DT)/12,",
				"          DEAL_TYPE_CD = substring(DEAL_NUMBER,1,2),",
				"          DEAL_NUMBER = replace(DEAL_NUMBER,substring(DEAL_NUMBER,1,2),''),",
				"          RCD_CRT_TMS = currentDate(),",
				"          START_DATE = currentDate(),",
				"          DEAL_ID = iifNull(DEAL_ID,\"exists\"),",
				"          RCD_MOD_TMS = currentDate(),",
				"          END_DATE = currentDate()) ~> derivedColumn1",
				"derivedColumn1 select(mapColumn(",
				"          PTNT_CD,",
				"          PHRMCY_NCPDP_NBR,",
				"          PHRMCY_NAT_PROV_ID_NBR,",
				"          PSCB_FIRST_NM,",
				"          PSCB_LAST_NM,",
				"          PHRMCY_NM,",
				"          PHRMCY_ADDR_CITY_NM,",
				"          PHRMCY_ADDR_ST_NM,",
				"          PHRMCY_ADDR_ZNE_NM,",
				"          PHRMCY_ADDR_ZIP_CD,",
				"          PSCB_EMAIL_ID,",
				"          PHRMCY_SYS_IVR_DTA_STRT_DT,",
				"          PHRMCY_SYS_IVR_DTA_STRT_QTR,",
				"          PHRMCY_SYS_IVR_DTA_STRT_YR,",
				"          PHRMCY_AGE,",
				"          DEAL_ID,",
				"          DEAL_TYPE_CD,",
				"          DEAL_NUMBER,",
				"          LANG_CD,",
				"          LANG_DESC,",
				"          RCD_CRT_TMS,",
				"          RCD_MOD_TMS,",
				"          START_DATE,",
				"          END_DATE,",
				"          PHRMCY_ADDR_ZNE_CD",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     mapColumn(",
				"          PTNT_CD,",
				"          PHRMCY_NCPDP_NBR,",
				"          PHRMCY_NAT_PROV_ID_NBR,",
				"          PSCB_FIRST_NM,",
				"          PSCB_LAST_NM,",
				"          PHRMCY_NM,",
				"          PHRMCY_ADDR_CITY_NM,",
				"          PHRMCY_ADDR_ST_NM,",
				"          PHRMCY_ADDR_ZNE_NM,",
				"          PHRMCY_ADDR_ZIP_CD,",
				"          PSCB_EMAIL_ID,",
				"          PHRMCY_SYS_IVR_DTA_STRT_DT,",
				"          PHRMCY_SYS_IVR_DTA_STRT_QTR,",
				"          PHRMCY_SYS_IVR_DTA_STRT_YR,",
				"          PHRMCY_AGE,",
				"          DEAL_ID,",
				"          DEAL_TYPE_CD,",
				"          DEAL_NUMBER,",
				"          LANG_CD,",
				"          LANG_DESC,",
				"          RCD_CRT_TMS,",
				"          RCD_MOD_TMS,",
				"          START_DATE,",
				"          END_DATE,",
				"          PHRMCY_ADDR_ZNE_CD",
				"     )) ~> tgt"
			]
		}
	}
}
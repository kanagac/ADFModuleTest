{
	"name": "DF_PTNT",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_SRC_PTNT",
						"type": "DatasetReference"
					},
					"name": "SRC1PHRMCY"
				},
				{
					"dataset": {
						"referenceName": "DS_SRC_PTNT",
						"type": "DatasetReference"
					},
					"name": "SRC2STATUS"
				},
				{
					"dataset": {
						"referenceName": "DS_SRC_PTNT",
						"type": "DatasetReference"
					},
					"name": "SRCLU"
				},
				{
					"dataset": {
						"referenceName": "DS_TGT_DIM_PTNT",
						"type": "DatasetReference"
					},
					"name": "TGTDIMPTNT"
				}
			],
			"sinks": [],
			"transformations": [
				{
					"name": "LeftJoinPhrmcyStatus"
				},
				{
					"name": "LeftJoinPhrmcyLuLanguage"
				},
				{
					"name": "TGTSurrogateKey"
				},
				{
					"name": "LeftSelect"
				},
				{
					"name": "RightSelect"
				},
				{
					"name": "FinalJoin"
				},
				{
					"name": "Transformations"
				}
			],
			"scriptLines": [
				"source(output(",
				"          PHRMCY_NAT_PROV_ID_NBR as string,",
				"          PHRMCY_NCPDP_NBR as double,",
				"          PTNT_CD as string,",
				"          PSCB_FIRST_NM as string,",
				"          PSCB_LAST_NM as string,",
				"          LANG_CD as string,",
				"          DEAL_ID as string,",
				"          PHRMCY_NM as string,",
				"          PHRMCY_ST_ADDR_LINE1_TXT as string,",
				"          PHRMCY_ADDR_ZIP_CD as double,",
				"          PHRMCY_ADDR_CITY_NM as string,",
				"          PHRMCY_ADDR_ST_CD as string,",
				"          PHRMCY_ADDR_ST_NAME as string,",
				"          PHRMCY_ADDR_ZNE_CD as string,",
				"          PHRMCY_ADDR_ZNE_NM as string,",
				"          PHRMCY_SYS_IVR_DTA_STRT_DT as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> SRC1PHRMCY",
				"source(output(",
				"          deal_id as string,",
				"          deal_nbr as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> SRC2STATUS",
				"source(output(",
				"          LANG_ID as integer,",
				"          LANG_CD as string,",
				"          LANG_DESC as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> SRCLU",
				"source(output(",
				"          PTNT_KEY as integer,",
				"          PTNT_ID as integer,",
				"          PTNT_CD as string,",
				"          PHRMCY_NCPDP_NBR as integer,",
				"          PHARMCY_NAT_PROV_ID_NBR as string,",
				"          PSCB_FIRST_NM as string,",
				"          PSCB_LAST_NM as string,",
				"          PHRMCT_NM as string,",
				"          PHRMCY_ADDR_CITY_NM as string,",
				"          PHRMCY_ADDR_ST_NM as string,",
				"          PHRMCY_ADDR_ZNE_NM as string,",
				"          PHRMCY_ADDR_ZIP_XD as string,",
				"          PSCB_EMAIL_ID as string,",
				"          PHRMCY_SYS_IVR_DTA_STRT_DT as string,",
				"          PHRMCY_SYS_IVR_DTA_STRT_QTR as string,",
				"          PHRMCY_SYS_IVR_DTA_STRT_YR as string,",
				"          PHRMCY_AGE as integer,",
				"          DEAL_ID as string,",
				"          DEAL_TYPE_CD as string,",
				"          DEAL_NUMBER as string,",
				"          LANG_CD as string,",
				"          LANG_DESC as string,",
				"          RCD_CRT_TMS as timestamp,",
				"          RCD_MOD_TMS as timestamp,",
				"          START_DATE as timestamp,",
				"          END_DATE as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> TGTDIMPTNT",
				"SRC1PHRMCY, SRC2STATUS join(SRC1PHRMCY@DEAL_ID == SRC2STATUS@deal_id",
				"     && SRC1PHRMCY@DEAL_ID == deal_nbr,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> LeftJoinPhrmcyStatus",
				"SRC1PHRMCY, SRCLU join(SRC1PHRMCY@LANG_CD == SRCLU@LANG_CD,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> LeftJoinPhrmcyLuLanguage",
				"TGTDIMPTNT keyGenerate(output(PTNT_KEY as long),",
				"     startAt: 1L,",
				"     stepValue: 1L) ~> TGTSurrogateKey",
				"LeftJoinPhrmcyStatus select(mapColumn(",
				"          PHRMCY_NAT_PROV_ID_NBR,",
				"          PHRMCY_NCPDP_NBR,",
				"          PTNT_CD,",
				"          PSCB_FIRST_NM,",
				"          PSCB_LAST_NM,",
				"          LANG_CD,",
				"          DEAL_ID = SRC1PHRMCY@DEAL_ID,",
				"          PHRMCY_NM,",
				"          PHRMCY_ST_ADDR_LINE = PHRMCY_ST_ADDR_LINE1_TXT,",
				"          PHRMCY_ADDR_ZIP_CD,",
				"          PHRMCY_ADDR_CITY_NM,",
				"          PHRMCY_ADDR_ST_CD,",
				"          PHRMCY_ADDR_ST_NAME,",
				"          PHRMCY_ADDR_ZNE_CD,",
				"          PHRMCY_ADDR_ZNE_NM,",
				"          PHRMCY_SYS_IVR_DTA_STRT_DT,",
				"          DEAL_NBR = deal_nbr",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> LeftSelect",
				"LeftJoinPhrmcyLuLanguage select(mapColumn(",
				"          LANG_CD = SRCLU@LANG_CD,",
				"          LANG_DESC",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> RightSelect",
				"LeftSelect, RightSelect join(LeftSelect@LANG_CD == RightSelect@LANG_CD,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> FinalJoin",
				"FinalJoin derive(PTNT_ID = toInteger(regexReplace(PTNT_CD, '[^0-9]', '')),",
				"          PTNT_CD = right(PTNT_CD, 4),",
				"          PHRMCY_NAT_PROV_ID_NBR = iif(isNull(PHRMCY_NAT_PROV_ID_NBR),'UNK',PHRMCY_NAT_PROV_ID_NBR),",
				"          PHRMCY_NM = replace(PHRMCY_NM, ',', ' '),",
				"          PHRMCY_ADDR_ST_NAME = initCap(PHRMCY_ADDR_ST_NAME),",
				"          PHRMCY_ADDR_ZNE_NM = initCap(PHRMCY_ADDR_ZNE_NM),",
				"          PHRMCY_ADDR_ZIP_CD = iif(\r",
				"    length(toString(PHRMCY_ADDR_ZIP_CD)) < 5,\r",
				"    concat('0', toString(PHRMCY_ADDR_ZIP_CD)),\r",
				"    toString(PHRMCY_ADDR_ZIP_CD)\r",
				"    ),",
				"          PHRMCY_SYS_IVR_DTA_STRT_DT = toDate(PHRMCY_SYS_IVR_DTA_STRT_DT),",
				"          PHRMCY_SYS_IVR_DTA_STRT_QTR = concat('Q',toString(addMonths(PHRMCY_SYS_IVR_DTA_STRT_DT, -3)),'-',toString(year(PHRMCY_SYS_IVR_DTA_STRT_DT))),",
				"          PHRMCY_SYS_IVR_DTA_STRT_YR = toString(year(PHRMCY_SYS_IVR_DTA_STRT_DT)),",
				"          PHRMCY_AGE = (PHRMCY_SYS_IVR_DTA_STRT_DT- currentDate())) ~> Transformations"
			]
		}
	}
}
{
	"name": "DFDIMPTNT",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_Source_LS",
						"type": "DatasetReference"
					},
					"name": "SourceSRCPHRMCY"
				},
				{
					"dataset": {
						"referenceName": "DS_Source_LS",
						"type": "DatasetReference"
					},
					"name": "SourceSTATUS"
				},
				{
					"dataset": {
						"referenceName": "DS_Source_LS",
						"type": "DatasetReference"
					},
					"name": "SourceLULANGUAGE"
				},
				{
					"dataset": {
						"referenceName": "DF_Target_LS",
						"type": "DatasetReference"
					},
					"name": "TargetDIMPTNT"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DF_Target_LS",
						"type": "DatasetReference"
					},
					"name": "Load"
				}
			],
			"transformations": [
				{
					"name": "SRCPHRMCYDerivedColumn"
				},
				{
					"name": "SelectSRCPHRMCY"
				},
				{
					"name": "PhrmcyStatusJoin"
				},
				{
					"name": "FirstJoinDC"
				},
				{
					"name": "ThirdJoin"
				},
				{
					"name": "derivedColumn1"
				},
				{
					"name": "select"
				}
			],
			"scriptLines": [
				"source(output(",
				"          PHRMCY_NAT_PROV_ID_NBR as string,",
				"          PHRMCY_NCPDP_NBR as double,",
				"          PTNT_CD as string,",
				"          PSCB_FIRST_NM as string,",
				"          PSCB_LAST_NM as string,",
				"          LANG_CD as string,",
				"          DEAL_ID as string,",
				"          PHRMCY_NM as string,",
				"          PHRMCY_ST_ADDR_LINE1_TXT as string,",
				"          PHRMCY_ADDR_ZIP_CD as double,",
				"          PHRMCY_ADDR_CITY_NM as string,",
				"          PHRMCY_ADDR_ST_CD as string,",
				"          PHRMCY_ADDR_ST_NAME as string,",
				"          PHRMCY_ADDR_ZNE_CD as string,",
				"          PHRMCY_ADDR_ZNE_NM as string,",
				"          PHRMCY_SYS_IVR_DTA_STRT_DT as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> SourceSRCPHRMCY",
				"source(output(",
				"          deal_id as string,",
				"          deal_nbr as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> SourceSTATUS",
				"source(output(",
				"          LANG_ID as integer,",
				"          LANG_CD as string,",
				"          LANG_DESC as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> SourceLULANGUAGE",
				"source(output(",
				"          PTNT_KEY as integer,",
				"          PTNT_ID as integer,",
				"          PTNT_CD as string,",
				"          PHRMCY_NCPDP_NBR as integer,",
				"          PHRMCY_NAT_PROV_ID_NBR as string,",
				"          PSCB_FIRST_NM as string,",
				"          PSCB_LAST_NM as string,",
				"          PHRMCY_NM as string,",
				"          PHRMCY_ADDR_CITY_NM as string,",
				"          PHRMCY_ADDR_ST_NM as string,",
				"          PHRMCY_ADDR_ZNE_NM as string,",
				"          PHRMCY_ADDR_ZIP_CD as string,",
				"          PSCB_EMAIL_ID as string,",
				"          PHRMCY_SYS_IVR_DTA_STRT_DT as string,",
				"          PHRMCY_SYS_IVR_DTA_STRT_QTR as string,",
				"          PHRMCY_SYS_IVR_DTA_STRT_YR as string,",
				"          PHRMCY_AGE as integer,",
				"          DEAL_ID as string,",
				"          DEAL_TYPE_CD as string,",
				"          DEAL_NUMBER as string,",
				"          LANG_CD as string,",
				"          LANG_DESC as string,",
				"          RCD_CRT_TMS as timestamp,",
				"          RCD_MOD_TMS as timestamp,",
				"          START_DATE as timestamp,",
				"          END_DATE as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> TargetDIMPTNT",
				"SourceSRCPHRMCY derive(PTNT_ID1 = split(PTNT_CD, '_')[1],",
				"          PTNT_CD1 = right(PTNT_CD, 4),",
				"          PHRMCY_NCPDP_NBR1 = PHRMCY_NCPDP_NBR,",
				"          PHRMCY_NAT_PROV_ID_NBR1 = iif(isNull(PHRMCY_NAT_PROV_ID_NBR), 'UNK' , PHRMCY_NAT_PROV_ID_NBR)\r",
				",",
				"          PSCB_FIRST_NM1 = PSCB_FIRST_NM,",
				"          PSCB_LAST_NM1 = PSCB_LAST_NM,",
				"          PHRMCY_NM1 = regexReplace(PHRMCY_NM, '[-&,]', ' '),",
				"          PHRMCY_ADDR_CITY_NM1 = iif(regexMatch(trim(PHRMCY_ADDR_CITY_NM), ' '), concat(left(regexSplit(PHRMCY_ADDR_CITY_NM,' ')[1],1),left(regexSplit(PHRMCY_ADDR_CITY_NM,' ')[2],1)), left(PHRMCY_ADDR_CITY_NM, 3))\r",
				",",
				"          PHRMCY_ADDR_ST_NM1 = initCap(PHRMCY_ADDR_ST_NAME),",
				"          PHRMCY_ADDR_ZNE_NM1 = initCap(PHRMCY_ADDR_ZNE_NM),",
				"          PHRMCY_ADDR_ZIP_CD1 = right(lpad(toString(PHRMCY_ADDR_ZIP_CD), 5, '0'),5),",
				"          PSCB_EMAIL_ID1 = concat(substring(PSCB_FIRST_NM,ceil(length(PSCB_FIRST_NM)/2)), left(PSCB_LAST_NM, 1),'@UN.com'),",
				"          PHRMCY_SYS_IVR_DTA_STRT_DT1 = toDate(PHRMCY_SYS_IVR_DTA_STRT_DT),",
				"          PHRMCY_SYS_IVR_DTA_STRT_QTR1 = concat('Q',toString(toInteger(round(month(PHRMCY_SYS_IVR_DTA_STRT_DT)/3))),'-',toString(year(PHRMCY_SYS_IVR_DTA_STRT_DT))),",
				"          PHRMCY_SYS_IVR_DTA_STRT_YR1 = year(PHRMCY_SYS_IVR_DTA_STRT_DT),",
				"          PHRMCY_AGE1 = minus(currentDate(),toDate(PHRMCY_SYS_IVR_DTA_STRT_DT))) ~> SRCPHRMCYDerivedColumn",
				"SRCPHRMCYDerivedColumn select(mapColumn(",
				"          LANG_CD,",
				"          DEAL_ID,",
				"          PTNT_ID1,",
				"          PTNT_CD1,",
				"          PHRMCY_NCPDP_NBR1,",
				"          PHRMCY_NAT_PROV_ID_NBR1,",
				"          PSCB_FIRST_NM1,",
				"          PSCB_LAST_NM1,",
				"          PHRMCY_NM1,",
				"          PHRMCY_ADDR_CITY_NM1,",
				"          PHRMCY_ADDR_ST_NM1,",
				"          PHRMCY_ADDR_ZNE_NM1,",
				"          PHRMCY_ADDR_ZIP_CD1,",
				"          PSCB_EMAIL_ID1,",
				"          PHRMCY_SYS_IVR_DTA_STRT_DT1,",
				"          PHRMCY_SYS_IVR_DTA_STRT_QTR1,",
				"          PHRMCY_SYS_IVR_DTA_STRT_YR1,",
				"          PHRMCY_AGE1",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> SelectSRCPHRMCY",
				"SelectSRCPHRMCY, SourceSTATUS join(SelectSRCPHRMCY@DEAL_ID == SourceSTATUS@deal_id,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> PhrmcyStatusJoin",
				"PhrmcyStatusJoin derive(DEAL_ID1 = iif(isNull(deal_nbr), 'Exists', 'Not Exists'),",
				"          DEAL_TYPE_CD1 = left(deal_nbr, 2),",
				"          DEAL_NUMBER1 = substring(deal_nbr, 3, length(deal_nbr))) ~> FirstJoinDC",
				"FirstJoinDC, SourceLULANGUAGE join(SelectSRCPHRMCY@LANG_CD == SourceLULANGUAGE@LANG_CD,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> ThirdJoin",
				"ThirdJoin derive(RCD_CRT_TMS = toDate(null()),",
				"          RCD_MOD_TMS = toDate(null()),",
				"          START_DATE = toDate(null()),",
				"          END_DATE = toDate(null())) ~> derivedColumn1",
				"derivedColumn1 select(mapColumn(",
				"          PTNT_ID = PTNT_ID1,",
				"          PTNT_CD = PTNT_CD1,",
				"          PHRMCY_NCPDP_NBR = PHRMCY_NCPDP_NBR1,",
				"          PHRMCY_NAT_PROV_ID_NBR = PHRMCY_NAT_PROV_ID_NBR1,",
				"          PSCB_FIRST_NM = PSCB_FIRST_NM1,",
				"          PSCB_LAST_NM = PSCB_LAST_NM1,",
				"          PHRMCY_NM = PHRMCY_NM1,",
				"          PHRMCY_ADDR_CITY_NM = PHRMCY_ADDR_CITY_NM1,",
				"          PHRMCY_ADDR_ST_NM = PHRMCY_ADDR_ST_NM1,",
				"          PHRMCY_ADDR_ZNE_NM = PHRMCY_ADDR_ZNE_NM1,",
				"          PHRMCY_ADDR_ZIP_CD = PHRMCY_ADDR_ZIP_CD1,",
				"          PSCB_EMAIL_ID = PSCB_EMAIL_ID1,",
				"          PHRMCY_SYS_IVR_DTA_STRT_DT = PHRMCY_SYS_IVR_DTA_STRT_DT1,",
				"          PHRMCY_SYS_IVR_DTA_STRT_QTR = PHRMCY_SYS_IVR_DTA_STRT_QTR1,",
				"          PHRMCY_SYS_IVR_DTA_STRT_YR = PHRMCY_SYS_IVR_DTA_STRT_YR1,",
				"          PHRMCY_AGE = PHRMCY_AGE1,",
				"          DEAL_ID = DEAL_ID1,",
				"          DEAL_TYPE_CD = DEAL_TYPE_CD1,",
				"          DEAL_NUMBER = DEAL_NUMBER1,",
				"          LANG_CD = SourceLULANGUAGE@LANG_CD,",
				"          LANG_DESC,",
				"          RCD_CRT_TMS,",
				"          RCD_MOD_TMS,",
				"          START_DATE,",
				"          END_DATE",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select",
				"select sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     mapColumn(",
				"          PTNT_ID,",
				"          PTNT_CD,",
				"          PHRMCY_NCPDP_NBR,",
				"          PHRMCY_NAT_PROV_ID_NBR,",
				"          PSCB_FIRST_NM,",
				"          PSCB_LAST_NM,",
				"          PHRMCY_NM,",
				"          PHRMCY_ADDR_CITY_NM,",
				"          PHRMCY_ADDR_ST_NM,",
				"          PHRMCY_ADDR_ZNE_NM,",
				"          PHRMCY_ADDR_ZIP_CD,",
				"          PSCB_EMAIL_ID,",
				"          PHRMCY_SYS_IVR_DTA_STRT_DT,",
				"          PHRMCY_SYS_IVR_DTA_STRT_QTR,",
				"          PHRMCY_SYS_IVR_DTA_STRT_YR,",
				"          PHRMCY_AGE,",
				"          DEAL_ID,",
				"          DEAL_TYPE_CD,",
				"          DEAL_NUMBER,",
				"          LANG_CD,",
				"          LANG_DESC,",
				"          RCD_CRT_TMS,",
				"          RCD_MOD_TMS,",
				"          START_DATE,",
				"          END_DATE",
				"     )) ~> Load"
			]
		}
	}
}